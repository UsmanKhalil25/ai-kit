{
  "$schema": "https://opencode.ai/config.json",
  "name": "Second Brain",
  "description": "Personal knowledge management vault with Obsidian integration",
  "instructions": [
    "AGENTS.md"
  ],
  "agent": {
    "researcher": {
      "description": "Runs web research via Tavily CLI",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "bash": {
          "*": "ask",
          "tvly *": "allow",
          "set *": "allow",
          "curl *": "allow",
          "which *": "allow"
        },
        "write": false,
        "edit": false
      }
    },
    "evaluator": {
      "description": "Objectively scores product ideas",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "bash": false,
        "write": false,
        "edit": false
      }
    },
    "formatter": {
      "description": "Formats Obsidian markdown notes",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "bash": {
          "cat *": "allow",
          "ls *": "allow"
        },
        "write": true,
        "edit": true
      }
    }
  }
}
